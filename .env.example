# PrivateAI Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Claude API (required) — get yours at https://console.anthropic.com/settings/keys
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ElevenLabs TTS (optional) — get yours at https://elevenlabs.io/
EXPO_PUBLIC_ELEVENLABS_API_KEY=sk_YOUR_KEY_HERE

# Tavily Web Search (optional) — get yours at https://tavily.com/
EXPO_PUBLIC_TAVILY_API_KEY=tvly-YOUR_KEY_HERE
