{
  "expo": {
    "name": "PrivateAI",
    "slug": "privateai",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "privateai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "PrivateAI uses your microphone for voice input. Audio is processed on-device only.",
        "NSSpeechRecognitionUsageDescription": "PrivateAI uses speech recognition to convert voice to text. Processing happens on-device.",
        "NSPhotoLibraryUsageDescription": "PrivateAI accesses your photo library to attach images for analysis.",
        "NSCameraUsageDescription": "PrivateAI uses the camera to capture images for analysis.",
        "NSFaceIDUsageDescription": "PrivateAI uses Face ID to encrypt and protect your private data vault.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.chowmein97sorganization.privateai",
      "entitlements": {
        "com.apple.developer.kernel.extended-virtual-addressing": true,
        "com.apple.developer.kernel.increased-memory-limit": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080d14",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.chowmein97sorganization.privateai"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#080d14"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7ac02962-765a-4774-afd3-4c13576655f8"
      }
    },
    "owner": "chowmein97s-organization"
  }
}
